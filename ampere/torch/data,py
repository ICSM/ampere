class _Data_Base(Module):
    """ The base class for all `ampere.torch` data objects. This includes individual
    data points, datasets, and data loaders. 
    
    Data objects are used to store and manipulate data in a way that is compatible with
    Ampere. They are intended to be used as a base class for all data objects in the
    `ampere.torch` namespace, and to be extended to include more complex data objects.
    
    Attributes:
        data: The data stored in the object. This can be any type of data, including
            a single data point, a list of data points, a dictionary of data points,
            or a data loader.
        target: The observed target data stored in the object. This can be any type of
            data, including a single data point, a list of data points, a dictionary of
            data points, or a data loader.
        likelihood: The likelihood function used to evaluate the data. This can be any
            type of likelihood, including a single likelihood, a list of likelihoods, or
            a dictionary of likelihoods.
        data_generating_process: The data generating process used to generate the data.
            This can be any type of data generating process, including a single data
            generating process, a list of data generating processes, or a dictionary of
            data generating processes.
        model_target: The model target used to generate the data. This can be any type of
            model target, including a single model target, a list of model targets, or a
            dictionary of model targets.
    
    Methods:
        __len__(): Returns the length of the data stored in the object.
        __getitem__(): Returns the data at the specified index.
        __iter__(): Returns an iterator over the data stored in the object.
        __next__(): Returns the next data point in the iterator.
        __repr__(): Returns a string representation of the data stored in the object.
        __str__(): Returns a string representation of the data stored in the object.
        __call__(): Returns the data stored in the object.
        likelihood(): Returns the likelihood function used to evaluate the data.
        log_likelihood(): Returns the log likelihood function used to evaluate the data.
        sample(): Returns a sample from the data generating process.
        log_prob(): Returns the log probability function used to evaluate the data.
    
    Example:
        >>> data = Data(data=[1, 2, 3])
        >>> data = Data(data={'a': 1, 'b': 2, 'c': 3})
        >>> data = Data(data=DataLoader(dataset, batch_size=32))
    """
    
    _data: Union[List[Any], Dict[str, Any], DataLoader] = None
    _data_uncertainty: Union[List[Any], Dict[str, Any], DataLoader] = None
    _target: Union[List[Any], Dict[str, Any], DataLoader] = None
    _target_uncertainty: Union[List[Any], Dict[str, Any], DataLoader] = None
    _likelihood: Union[Likelihood, Module] = None
    _data_generating_process: Module = None
    _model_target: Union[str, List[str], Dict[str, str]] = None


    def __init__(self, 
                 data: Union[List[Any], Dict[str, Any], DataLoader] = None,
                 target: Union[List[Any], Dict[str, Any], DataLoader] = None,
                 likelihood: Union[Likelihood, Module] = None,
                 data_generating_process: Module = None,
                 model_target: Union[str, List[str], Dict[str, str]] = None,
                 *args, **kwargs) -> None:
        super().__init__(*args, **kwargs)
        self.data = data
        self.target = target
        self.likelihood = likelihood
        self.data_generating_process = data_generating_process
        self.model_target = model_target

    @property
    def data(self):
        return self._data

    @data.setter
    def data(self, data):
        self._data = torch.register_buffer('data', data) if isinstance(data, torch.Tensor) else data

    @property
    def target(self):
        return self._target

    @target.setter
    def target(self, target):
        self._target = torch.register_buffer('target', target) if isinstance(target, torch.Tensor) else target

    @property
    def likelihood(self):
        return self._likelihood
    
    @likelihood.setter
    def likelihood(self, likelihood):
        self._likelihood = likelihood

    @property
    def data_generating_process(self):
        return self._data_generating_process
    
    @data_generating_process.setter
    def data_generating_process(self, 
                                data_generating_process: Union[DataGeneratingProcess, Sequential, List[DataGeneratingProcess]]):
        if isinstance(data_generating_process, Sequential):
            self._data_generating_process = data_generating_process
        elif isinstance(data_generating_process, list):
            self._data_generating_process = Sequential(data_generating_process)
        elif isinstance(data_generating_process, DataGeneratingProcess):
            self._data_generating_process = data_generating_process
        else:
            raise ValueError(f"Invalid data generating process: {data_generating_process}")

    def __len__(self):
        return len(self.data)

    def __getitem__(self, idx):
        return self.data[idx]

    def __iter__(self):
        return iter(self.data)

    def __next__(self):
        return next(self.data)

    def __repr__(self):
        return f"{self.__class__.__name__}"

    def __str__(self):
        return f"{self.__class__.__name__}"

    def forward(self, *args, **kwargs):
        return self.data

    def likelihood(self, *args, **kwargs):
        raise NotImplementedError

    def log_likelihood(self, *args, **kwargs):
        raise NotImplementedError

    def sample(self, *args, **kwargs):
        raise NotImplementedError

    def log_prob(self, *args, **kwargs):
        raise NotImplementedError



class Data(_Data_Base):
    def log_likelihood(self, model_output: Dict[torch.Tensor, torch.Tensor],
                       *args, **kwargs):
        # First get the model output
        model_output = model_output[self._model_target]

        # Then push the model output through the data generating process
        data, model_data, model_target = self._data_generating_process(self.data,
                                                     model_output['data'],
                                                     model_output['target'])

        # Then compute the residuals
        residuals = self._target - model_target

        # Then compute the log likelihood
        log_likelihood = self._likelihood.log_likelihood(residuals)

        # Then return the log likelihood
        return log_likelihood


